#!/bin/bash
# NEON ERP - Cliente de conexao (macOS)
# Versao: 0.1.0

SERVIDOR="35.247.225.22"
PORTA=22

clear
echo "╔═══════════════════════════════════════╗"
echo "║         NEON ERP - Conexao            ║"
echo "╚═══════════════════════════════════════╝"
echo ""

read -p "Usuario: " USUARIO
if [ -z "$USUARIO" ]; then
    echo "Usuario nao pode ser vazio."
    exit 1
fi

echo "Conectando ao servidor NEON..."
echo ""
ssh -o ServerAliveInterval=60 -o ServerAliveCountMax=3 -p "$PORTA" "$USUARIO@$SERVIDOR"
